+
+# LG-RSD (Local-Global Region Self-Distillation) ---------------------------------------------------------------
+enable_lgrsd: False # (bool) enable train-time-only LG-RSD loss (no inference overhead)
+lgrsd_lambda: 0.5 # (float) weight of LG-RSD loss
+lgrsd_topk_per_image: 16 # (int) max GT boxes sampled per image to compute LG-RSD
+lgrsd_crop_size: 224 # (int) crop patch size for teacher view
+lgrsd_roi_size: 7 # (int) ROIAlign output size for student view
+lgrsd_feature_level: auto # (str) 'auto' (P3/P4/P5 by scale) or 'P3-only'
+lgrsd_embed_dim: 256 # (int) embedding dim for z_roi/z_crop
+enable_region_contrastive: False # (bool) optional InfoNCE term (default off)
